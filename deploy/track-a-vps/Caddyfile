{
    email {$ACME_EMAIL}
}

www.stratevia.eu {
    redir https://stratevia.eu{uri} permanent
}

stratevia.eu {
    encode zstd gzip

    @api path /healthz /agents* /dashboard* /specialists* /personal-assistant* /connectors* /knowledge* /workflows* /audit* /approvals* /public*
    handle @api {
        reverse_proxy api:8000
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
