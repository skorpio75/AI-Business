CLIENT_SLUG=client-template
CLIENT_NAME=Template Company
TENANT_ID=client-template
TRACK=track_b_client
PRIMARY_TRACK=track_b_client
RUNTIME_ENV_FILE=config/client-template/deployment.env.example

APP_NAME=enterprise-agent-platform-client-template
ENV=client-template
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5440/client_template_platform
POSTGRES_DB=client_template_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_PORT=5440
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_RELEASE=

INBOX_CONNECTOR=null
CALENDAR_CONNECTOR=null
PERSONAL_ASSISTANT_ACCOUNT_ID=me
PERSONAL_ASSISTANT_CALENDAR_ID=primary

GOOGLE_SECRETS_PATH=secrets/client-template/google-oauth.json
MICROSOFT_GRAPH_SECRETS_PATH=secrets/client-template/microsoft-graph.json

CLIENT_DOCUMENTS_DIR=data/clients/client-template/documents
CLIENT_LOGS_DIR=data/clients/client-template/logs
CLIENT_EXPORTS_DIR=data/clients/client-template/exports
CLIENT_VECTOR_DIR=data/clients/client-template/vector
CLIENT_PROMPT_OVERRIDE_DIR=prompts/clients/client-template
