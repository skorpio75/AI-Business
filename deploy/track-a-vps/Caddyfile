www.stratevia.eu {
    redir https://stratevia.eu{uri} permanent
}

stratevia.eu {
    encode zstd gzip
    root * /srv

    @api path /healthz /agents* /dashboard* /specialists* /personal-assistant* /connectors* /knowledge* /workflows* /audit* /approvals*
    reverse_proxy @api api:8000

    try_files {path} /index.html
    file_server
}
