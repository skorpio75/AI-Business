# Site and routing
PUBLIC_SITE_ADDR=:80
ACME_EMAIL=
VITE_API_BASE_URL=same-origin

# Host persistence root on the VPS
TRACK_A_DATA_ROOT=/opt/ai-business-data

# Application identity
ENV=production
APP_NAME=enterprise-agent-platform
PRIMARY_TRACK=track_a_internal
TENANT_ID=internal
API_HOST=0.0.0.0
API_PORT=8000

# Database
POSTGRES_DB=agent_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=change-this-now

# Model routing
LOCAL_MODEL=qwen2.5:1.5b-instruct-q4_K_M
OLLAMA_BASE_URL=http://ollama:11434
MODEL_TIMEOUT_SECONDS=60
CLOUD_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
FORCE_LOCAL_ONLY=false
LOCAL_CONFIDENCE_THRESHOLD=0.80
MAX_LOCAL_INPUT_CHARS=3000

# Email drafting model posture
EMAIL_LOCAL_MODEL=llama3.2:3b
EMAIL_LOCAL_TIMEOUT_SECONDS=30
EMAIL_LOCAL_TEXT_NUM_PREDICT=180
EMAIL_STRONG_LOCAL_MODEL=qwen2.5:1.5b-instruct-q4_K_M
EMAIL_STRONG_LOCAL_TIMEOUT_SECONDS=60
EMAIL_STRONG_LOCAL_TEXT_NUM_PREDICT=220
EMAIL_UPGRADE_ON_WEAK_DRAFT=true
EMAIL_CLOUD_MAX_TOKENS=400

# Optional observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_RELEASE=

# Connector defaults
INBOX_CONNECTOR=null
CALENDAR_CONNECTOR=null
PERSONAL_ASSISTANT_ACCOUNT_ID=me
PERSONAL_ASSISTANT_CALENDAR_ID=primary
PERSONAL_ASSISTANT_WINDOW_HOURS=24
PERSONAL_ASSISTANT_INBOX_LOOKBACK_HOURS=24

# Google connector bootstrap
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/google/callback
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SECRETS_PATH=secrets/internal/google-oauth.json

# Microsoft Graph connector bootstrap
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_GRAPH_SCOPES=offline_access https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Calendars.Read
MICROSOFT_GRAPH_ACCESS_TOKEN=
MICROSOFT_GRAPH_REFRESH_TOKEN=
MICROSOFT_GRAPH_SECRETS_PATH=secrets/internal/microsoft-graph.json
