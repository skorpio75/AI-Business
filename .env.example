ENV=local
APP_NAME=enterprise-agent-platform
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://agent:agent@localhost:5433/agent_platform
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:1.5b
CLOUD_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
LOCAL_CONFIDENCE_THRESHOLD=0.80
MAX_LOCAL_INPUT_CHARS=3000
FORCE_LOCAL_ONLY=false
INBOX_CONNECTOR=null
CALENDAR_CONNECTOR=null
PERSONAL_ASSISTANT_ACCOUNT_ID=me
PERSONAL_ASSISTANT_CALENDAR_ID=primary
PERSONAL_ASSISTANT_WINDOW_HOURS=24
PERSONAL_ASSISTANT_INBOX_LOOKBACK_HOURS=24
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/google/callback
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SECRETS_PATH=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_GRAPH_SCOPES=offline_access https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Calendars.Read
MICROSOFT_GRAPH_ACCESS_TOKEN=
MICROSOFT_GRAPH_REFRESH_TOKEN=
MICROSOFT_GRAPH_SECRETS_PATH=
POSTGRES_DB=agent_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_PORT=5433
